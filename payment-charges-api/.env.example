# Required: shared HMAC secret used to validate Fake Bank webhooks.
# Must match fake-bank-service WEBHOOK_SECRET.
WEBHOOK_SECRET=replace-with-a-strong-shared-secret

# Optional/conditional: API key expected by protected endpoints.
EXTERNAL_API_KEY=replace-with-a-local-api-key

# Redis used for charge TTL, idempotency, event deduplication, and rate limiting.
# Use redis://redis:6379/0 when running inside Docker Compose.
REDIS_URL=redis://localhost:6379/0

# Optional Flask environment marker for local development.
FLASK_ENV=development
