# Required for integration: shared HMAC secret used to sign webhooks.
# Must match payment-charges-api WEBHOOK_SECRET.
WEBHOOK_SECRET=replace-with-a-strong-shared-secret

# Optional: example Payment API webhook receiver URL for local integration.
# The main PIX flow currently requires webhook_url in the charge payload.
WEBHOOK_URL=http://localhost:5000/webhooks/pix

# Webhook retry and timeout configuration.
MAX_RETRIES=5
INITIAL_DELAY_SECONDS=1
BACKOFF_MULTIPLIER=2
MAX_DELAY_SECONDS=10
TIMEOUT_SECONDS=5
